namespace std {

// Mutex types
class mutex {
    void* _handle;
    bool _locked;
    
public:
    constexpr mutex() noexcept : _handle(nullptr), _locked(false) {}
    ~mutex() = default;
    
    mutex(const mutex&) = delete;
    mutex& operator=(const mutex&) = delete;
    
    void lock() {
        // Platform-specific lock
        _locked = true;
    }
    
    bool try_lock() noexcept {
        if (_locked) return false;
        _locked = true;
        return true;
    }
    
    void unlock() noexcept {
        _locked = false;
    }
    
    using native_handle_type = void*;
    native_handle_type native_handle() { return _handle; }
};

class recursive_mutex {
    void* _handle;
    unsigned int _count;
    
public:
    recursive_mutex() : _handle(nullptr), _count(0) {}
    ~recursive_mutex() = default;
    
    recursive_mutex(const recursive_mutex&) = delete;
    recursive_mutex& operator=(const recursive_mutex&) = delete;
    
    void lock() {
        ++_count;
    }
    
    bool try_lock() noexcept {
        ++_count;
        return true;
    }
    
    void unlock() noexcept {
        if (_count > 0) --_count;
    }
    
    using native_handle_type = void*;
    native_handle_type native_handle() { return _handle; }
};

class timed_mutex {
    mutex _mutex;
    
public:
    timed_mutex() = default;
    ~timed_mutex() = default;
    
    timed_mutex(const timed_mutex&) = delete;
    timed_mutex& operator=(const timed_mutex&) = delete;
    
    void lock() { _mutex.lock(); }
    bool try_lock() noexcept { return _mutex.try_lock(); }
    void unlock() noexcept { _mutex.unlock(); }
    
    template<typename Rep, typename Period>
    bool try_lock_for(const chrono::duration<Rep, Period>& timeout_duration) {
        (void)timeout_duration;
        return try_lock();
    }
    
    template<typename Clock, typename Duration>
    bool try_lock_until(const chrono::time_point<Clock, Duration>& timeout_time) {
        (void)timeout_time;
        return try_lock();
    }
    
    using native_handle_type = void*;
    native_handle_type native_handle() { return _mutex.native_handle(); }
};

class recursive_timed_mutex {
    recursive_mutex _mutex;
    
public:
    recursive_timed_mutex() = default;
    ~recursive_timed_mutex() = default;
    
    recursive_timed_mutex(const recursive_timed_mutex&) = delete;
    recursive_timed_mutex& operator=(const recursive_timed_mutex&) = delete;
    
    void lock() { _mutex.lock(); }
    bool try_lock() noexcept { return _mutex.try_lock(); }
    void unlock() noexcept { _mutex.unlock(); }
    
    template<typename Rep, typename Period>
    bool try_lock_for(const chrono::duration<Rep, Period>& timeout_duration) {
        (void)timeout_duration;
        return try_lock();
    }
    
    template<typename Clock, typename Duration>
    bool try_lock_until(const chrono::time_point<Clock, Duration>& timeout_time) {
        (void)timeout_time;
        return try_lock();
    }
};

// Lock tags
struct defer_lock_t { explicit defer_lock_t() = default; };
struct try_to_lock_t { explicit try_to_lock_t() = default; };
struct adopt_lock_t { explicit adopt_lock_t() = default; };

inline constexpr defer_lock_t defer_lock{};
inline constexpr try_to_lock_t try_to_lock{};
inline constexpr adopt_lock_t adopt_lock{};

// lock_guard
template<typename Mutex>
class lock_guard {
    Mutex& _mutex;
    
public:
    using mutex_type = Mutex;
    
    explicit lock_guard(Mutex& m) : _mutex(m) {
        _mutex.lock();
    }
    
    lock_guard(Mutex& m, adopt_lock_t) noexcept : _mutex(m) {}
    
    ~lock_guard() {
        _mutex.unlock();
    }
    
    lock_guard(const lock_guard&) = delete;
    lock_guard& operator=(const lock_guard&) = delete;
};

// unique_lock
template<typename Mutex>
class unique_lock {
    Mutex* _mutex;
    bool _owns;
    
public:
    using mutex_type = Mutex;
    
    unique_lock() noexcept : _mutex(nullptr), _owns(false) {}
    
    explicit unique_lock(Mutex& m) : _mutex(&m), _owns(true) {
        _mutex->lock();
    }
    
    unique_lock(Mutex& m, defer_lock_t) noexcept : _mutex(&m), _owns(false) {}
    
    unique_lock(Mutex& m, try_to_lock_t) : _mutex(&m), _owns(_mutex->try_lock()) {}
    
    unique_lock(Mutex& m, adopt_lock_t) noexcept : _mutex(&m), _owns(true) {}
    
    ~unique_lock() {
        if (_owns) _mutex->unlock();
    }
    
    unique_lock(const unique_lock&) = delete;
    unique_lock& operator=(const unique_lock&) = delete;
    
    unique_lock(unique_lock&& other) noexcept 
        : _mutex(other._mutex), _owns(other._owns) {
        other._mutex = nullptr;
        other._owns = false;
    }
    
    unique_lock& operator=(unique_lock&& other) noexcept {
        if (_owns) _mutex->unlock();
        _mutex = other._mutex;
        _owns = other._owns;
        other._mutex = nullptr;
        other._owns = false;
        return *this;
    }
    
    void lock() {
        if (!_mutex) return;
        _mutex->lock();
        _owns = true;
    }
    
    bool try_lock() {
        if (!_mutex) return false;
        _owns = _mutex->try_lock();
        return _owns;
    }
    
    void unlock() {
        if (_owns) {
            _mutex->unlock();
            _owns = false;
        }
    }
    
    void swap(unique_lock& other) noexcept {
        Mutex* tmp_m = _mutex;
        bool tmp_o = _owns;
        _mutex = other._mutex;
        _owns = other._owns;
        other._mutex = tmp_m;
        other._owns = tmp_o;
    }
    
    Mutex* release() noexcept {
        Mutex* m = _mutex;
        _mutex = nullptr;
        _owns = false;
        return m;
    }
    
    bool owns_lock() const noexcept { return _owns; }
    explicit operator bool() const noexcept { return _owns; }
    Mutex* mutex() const noexcept { return _mutex; }
};

template<typename Mutex>
void swap(unique_lock<Mutex>& x, unique_lock<Mutex>& y) noexcept {
    x.swap(y);
}

// scoped_lock (C++17)
template<typename... MutexTypes>
class scoped_lock;

template<typename Mutex>
class scoped_lock<Mutex> {
    Mutex& _mutex;
    
public:
    explicit scoped_lock(Mutex& m) : _mutex(m) {
        _mutex.lock();
    }
    
    scoped_lock(adopt_lock_t, Mutex& m) noexcept : _mutex(m) {}
    
    ~scoped_lock() {
        _mutex.unlock();
    }
    
    scoped_lock(const scoped_lock&) = delete;
    scoped_lock& operator=(const scoped_lock&) = delete;
};

template<>
class scoped_lock<> {
public:
    explicit scoped_lock() = default;
    explicit scoped_lock(adopt_lock_t) noexcept {}
    ~scoped_lock() = default;
    
    scoped_lock(const scoped_lock&) = delete;
    scoped_lock& operator=(const scoped_lock&) = delete;
};

// once_flag and call_once
struct once_flag {
    bool _called;
    constexpr once_flag() noexcept : _called(false) {}
    
    once_flag(const once_flag&) = delete;
    once_flag& operator=(const once_flag&) = delete;
};

template<typename Callable, typename... Args>
void call_once(once_flag& flag, Callable&& f, Args&&... args) {
    if (!flag._called) {
        f(static_cast<Args&&>(args)...);
        flag._called = true;
    }
}

// Generic lock functions
template<typename L1, typename L2>
void lock(L1& l1, L2& l2) {
    l1.lock();
    if (!l2.try_lock()) {
        l1.unlock();
        l2.lock();
        if (!l1.try_lock()) {
            l2.unlock();
            lock(l1, l2);
        }
    }
}

template<typename L1, typename L2>
int try_lock(L1& l1, L2& l2) {
    if (!l1.try_lock()) return 0;
    if (!l2.try_lock()) {
        l1.unlock();
        return 1;
    }
    return -1;
}

