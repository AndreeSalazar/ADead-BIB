/*
 * ADead-BIB C++ Standard Library
 * iostream - Basic I/O streams
 */

#ifndef _ADEAD_IOSTREAM
#define _ADEAD_IOSTREAM

#include "../c/stdio.h"

namespace std {

class ostream {
public:
    ostream& operator<<(const char* s) {
        printf("%s", s);
        return *this;
    }
    
    ostream& operator<<(int n) {
        printf("%d", n);
        return *this;
    }
    
    ostream& operator<<(long n) {
        printf("%ld", n);
        return *this;
    }
    
    ostream& operator<<(long long n) {
        printf("%lld", n);
        return *this;
    }
    
    ostream& operator<<(unsigned int n) {
        printf("%u", n);
        return *this;
    }
    
    ostream& operator<<(double d) {
        printf("%f", d);
        return *this;
    }
    
    ostream& operator<<(char c) {
        printf("%c", c);
        return *this;
    }
    
    ostream& operator<<(void* p) {
        printf("%p", p);
        return *this;
    }
    
    ostream& operator<<(ostream& (*manip)(ostream&)) {
        return manip(*this);
    }
};

class istream {
public:
    istream& operator>>(int& n) {
        scanf("%d", &n);
        return *this;
    }
    
    istream& operator>>(long& n) {
        scanf("%ld", &n);
        return *this;
    }
    
    istream& operator>>(double& d) {
        scanf("%lf", &d);
        return *this;
    }
    
    istream& operator>>(char* s) {
        scanf("%s", s);
        return *this;
    }
    
    istream& operator>>(char& c) {
        scanf("%c", &c);
        return *this;
    }
};

/* Standard streams */
extern ostream cout;
extern ostream cerr;
extern istream cin;

/* Manipulators */
inline ostream& endl(ostream& os) {
    printf("\n");
    fflush(stdout);
    return os;
}

inline ostream& flush(ostream& os) {
    fflush(stdout);
    return os;
}

} /* namespace std */

#endif /* _ADEAD_IOSTREAM */
